# ============================================
# Clara Answers Pipeline - Environment Variables
# ============================================

# n8n Configuration
N8N_USER=admin
N8N_PASSWORD=clarapipeline

# Timezone
TIMEZONE=America/New_York

# Ollama Configuration (optional - for LLM-based extraction)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Whisper Configuration (for local transcription)
WHISPER_MODEL=base

# Pipeline Settings
USE_LLM=false
DRY_RUN=false
